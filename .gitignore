# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Editors ---
.vscode/
.idea/
.cursor/

# --- Obsidian: personal UI state (regenerated per machine) ---
.obsidian/workspace.json
.obsidian/cache/

# --- Obsidian: plugin runtime / dependencies (regenerable) ---
.obsidian/plugins/*/node_modules/

# --- Auto-generated tool data (not source of truth) ---
# Skills we explicitly install are tracked, but agents/commands subdirs are auto-generated
.claude/agents/
.claude/commands/
.claudian/
.smart-env/

# --- Trash / temp ---
.Trash/

# --- Local agent runtime data ---
*.log
*.tmp

# --- Python build artifacts (regenerated on every run) ---
__pycache__/
*.pyc
*.pyo

# --- Local runtime / agent intake (per-session, regenerable) ---
.opencode/
99 _system/intake-log/

# --- Glass server virtualenv (machine-specific, regenerable from requirements.txt) ---
99 _system/mcps/glass-server/.venv/

# --- Mavis daemon + Wholeness runtime data (regenerated by tool, not source) ---
99 _system/logs/daemon-runs.jsonl
99 _system/logs/crucible-routing.jsonl
99 _system/logs/skillopt-runs.jsonl
99 _system/logs/ledger-snapshot.json
99 _system/mcps/vault-brain/index.json
99 _system/mcps/wholeness-engine/cache.jsonl
