      "label": "Sandbox Layer (Safety)",
      "x": -2000,
      "y": -1180,
      "width": 4000,
      "height": 500,
      "color": "3",
      "background": "3"
    },
    {
      "id": "group-software",
      "type": "group",
      "label": "Software Layer (Mavis EA + Esalen)",
      "x": -2000,
      "y": -660,
      "width": 4000,
      "height": 700,
      "color": "4",
      "background": "4"
    },
    {
      "id": "group-context",
